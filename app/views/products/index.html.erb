<% content_for :title, "Quilla Alma | Ecuadorian-Inspired Goods" %>

<section class="hero">
  <div class="hero__content">
    <p class="eyebrow">Ecuadorian-inspired goods in Winnipeg</p>

    <h1>Craft, flavour, and tradition</h1>

    <p>
      Explore artisan coffee, chocolate, textiles, decor, crafts,
      and thoughtfully curated gifts.
    </p>
  </div>
</section>

<section class="catalog">
  <div class="section-heading">
    <div>
      <p class="eyebrow">Our collection</p>
      <h2>Available products</h2>
    </div>

    <p><%= pluralize(@products.total_count, "product") %></p>
  </div>

  <%= form_with url: products_path, method: :get, local: true, class: "catalog-filters" do |form| %>
    <div>
      <%= form.label :query, "Search products" %>
      <%= form.search_field :query,
                            value: params[:query],
                            placeholder: "Search by name or description" %>
    </div>

    <div>
      <%= form.label :category_id, "Category" %>
      <%= form.collection_select :category_id,
                                @categories,
                                :id,
                                :name,
                                { include_blank: "All categories",
                                  selected: params[:category_id] } %>
    </div>

    <div>
      <%= form.check_box :on_sale,
                        { checked: params[:on_sale] == "1" },
                        "1",
                        "0" %>
      <%= form.label :on_sale, "On sale only" %>
    </div>

    <%= form.submit "Search and filter" %>
    <%= link_to "Clear filters", products_path %>
  <% end %>

  <% if @products.any? %>
    <div class="product-grid">
      <%= render @products %>
    </div>

    <%= paginate @products %>
  <% else %>
    <p>No products are currently available.</p>
  <% end %>
</section>
